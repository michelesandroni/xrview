{
  "name": "xrview",
  "version": "0.9.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build-xr": "node scripts/build-xr.mjs",
    "tauri": "npm run build-xr && tauri",
    "tauri-build": "npm run build-xr && tauri build -- --target-dir ../dist-release",
    "tauri-dev": "npm run build-xr && tauri dev -- --target-dir ../dist-debug",
    "--DO-NOT-USE--preview": "vite preview",
    "build": "tsc && vite build",
    "build-icons": "npm run tauri icon"
  },
  "dependencies": {
    "@gravity-ui/icons": "^2.18.0",
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@iwer/devui": "^1.1.2",
    "@iwer/sem": "^0.2.5",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "iwer": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.2.2",
    "webxr-polyfill": "^2.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "esbuild": "^0.27.4",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
